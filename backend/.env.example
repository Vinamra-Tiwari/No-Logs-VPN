PORT=5000
ADMIN_PASSWORD=change_me_to_a_strong_password
JWT_SECRET=change_me_to_a_random_string
DB_ENCRYPTION_KEY=exactly_32_characters_long_key!!

# ── VPS / WireGuard ──
VPS_HOST=your.vps.ip.address
VPS_USER=root
VPS_SSH_KEY=~/.ssh/vpn_key
WG_INTERFACE=wg1

# Auto-fetched from VPS at startup if left as placeholder
SERVER_PUBLIC_KEY=auto
SERVER_ENDPOINT=your.vps.ip.address:51821
